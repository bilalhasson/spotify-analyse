# Copy to .env.local for local dev (git-ignored). Set the same vars in Railway.
# True PKCE flow — no client secret required.

SPOTIFY_CLIENT_ID=
# Local dev uses the loopback IP (Spotify no longer accepts "localhost").
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback
# 32+ char random string, e.g.  openssl rand -base64 32
SESSION_SECRET=
